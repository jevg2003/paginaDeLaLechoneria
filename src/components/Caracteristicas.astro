---
const checkItems = ['Responsabilidad', 'Confianza', 'Compromiso', 'Don de servicio', 'Eficacia'];
---

<section id="caracteristicas" class="relative overflow-hidden bg-brand-800 py-20 text-cream-50 sm:py-28">
	<div class="pointer-events-none absolute inset-0" aria-hidden="true">
		<span class="absolute -left-24 top-16 size-72 rounded-full bg-brand-600/40 blur-3xl"></span>
		<span class="absolute -right-20 bottom-10 size-80 rounded-full bg-gold-400/10 blur-3xl"></span>
	</div>

	<div class="relative mx-auto max-w-6xl px-4">
		<div class="mx-auto max-w-3xl text-center">
			<h2 class="caracteristicas-title mb-12 text-3xl font-extrabold leading-tight text-cream-50 sm:text-4xl lg:text-5xl">
				Calidad, cercanía y compromiso <span class="text-gold-400">en cada entrega</span>
			</h2>
		</div>

		<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 lg:gap-5">
			<div class="caracteristica-block flex flex-col rounded-3xl bg-cream-50 p-7 text-brand-900 shadow-xl sm:col-span-2 lg:row-span-2">
				<span class="caracteristica-icon mb-4 flex size-12 items-center justify-center rounded-2xl bg-brand-600 text-gold-400">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-6">
						<path d="M12 21c-4.5-3.2-8-6.4-8-10a5 5 0 0 1 9-3 5 5 0 0 1 9 3c0 3.6-3.5 6.8-8 10z"></path>
					</svg>
				</span>
				<h3 class="mb-2 text-2xl font-extrabold text-brand-800">Nuestros Valores</h3>
				<p class="mb-5 text-brand-900/70">Para lograr nuestros objetivos, contamos con personal calificado que brinda:</p>
				<ul class="caracteristica-valores mt-auto space-y-3">
					{
						checkItems.map((item) => (
							<li class="caracteristica-valor flex items-center gap-3 text-lg font-semibold text-brand-900">
								<span class="flex size-7 shrink-0 items-center justify-center rounded-full bg-gold-500/20">
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="caracteristica-check size-4 text-gold-600">
										<polyline points="20 6 9 17 4 12" />
									</svg>
								</span>
								{item}
							</li>
						))
					}
				</ul>
			</div>

			<div class="caracteristica-block rounded-3xl bg-cream-50 p-6 text-brand-900 shadow-xl">
				<span class="caracteristica-icon mb-4 flex size-12 items-center justify-center rounded-2xl bg-brand-600 text-gold-400">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-6">
						<path d="M21 11.5a8.38 8.38 0 0 1-8.5 8.5 8.5 8.5 0 0 1-3.8-.9L3 21l1.9-5.7a8.5 8.5 0 1 1 16.1-3.8z"></path>
					</svg>
				</span>
				<h3 class="mb-2 text-xl font-extrabold text-brand-800">Compra Fácil</h3>
				<p class="text-brand-900/70">Contamos con canales de atención para que compres con seguridad.</p>
			</div>

			<div class="caracteristica-block rounded-3xl bg-cream-50 p-6 text-brand-900 shadow-xl">
				<span class="caracteristica-icon mb-4 flex size-12 items-center justify-center rounded-2xl bg-brand-600 text-gold-400">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-6">
						<path d="M1 8h13v8H1z"></path>
						<path d="M14 11h4l3 3v2h-7z"></path>
						<circle cx="6" cy="18" r="2"></circle>
						<circle cx="17" cy="18" r="2"></circle>
					</svg>
				</span>
				<h3 class="mb-2 text-xl font-extrabold text-brand-800">Entrega a Domicilio</h3>
				<p class="text-brand-900/70">En la ciudad de Cali y alrededores.</p>
			</div>

			<div class="caracteristica-block rounded-3xl bg-cream-50 p-6 text-brand-900 shadow-xl lg:col-span-2">
				<span class="caracteristica-icon mb-4 flex size-12 items-center justify-center rounded-2xl bg-brand-600 text-gold-400">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-6">
						<path d="M6 13a6 6 0 1 1 12 0v2H6z"></path>
						<path d="M4 15h16v3a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1z"></path>
					</svg>
				</span>
				<h3 class="mb-2 text-xl font-extrabold text-brand-800">Personal Calificado</h3>
				<p class="text-brand-900/70">Somos expertos en la preparación de lechona con nuestra propia receta.</p>
			</div>
		</div>
	</div>
</section>

<style>
	/* transform is GSAP-owned (entrance + hover lift): a CSS transition on it
	   would fight the tween and leave cards stuck mid-flight. */
	.caracteristica-block {
		transition: box-shadow 0.35s cubic-bezier(0.22, 1, 0.36, 1);
	}
	.caracteristica-block:hover {
		box-shadow: 0 22px 40px -18px rgb(0 0 0 / 0.45);
	}
</style>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	import { initCardHoverLift } from '../lib/cardHoverLift';

	gsap.registerPlugin(ScrollTrigger);

	const mm = gsap.matchMedia();

	mm.add({ reduceMotion: '(prefers-reduced-motion: reduce)', okMotion: '(prefers-reduced-motion: no-preference)' }, (context) => {
		const { reduceMotion } = context.conditions as { reduceMotion: boolean };

		if (reduceMotion) {
			gsap.from('.caracteristica-block', {
				autoAlpha: 0,
				duration: 0.3,
				stagger: 0.05,
				scrollTrigger: { trigger: '#caracteristicas', start: 'top 75%', toggleActions: 'play none none none' },
			});
			return () => {};
		}

		const entrance = gsap.timeline({
			scrollTrigger: {
				trigger: '#caracteristicas',
				start: 'top 70%',
				toggleActions: 'play none none none',
			},
			defaults: { ease: 'power3.out' },
		});

		entrance
			.from('.caracteristicas-title', { autoAlpha: 0, y: 40, duration: 0.7 })
			.from(
				'.caracteristica-block',
				{ autoAlpha: 0, y: 60, duration: 0.7, stagger: 0.12 },
				'-=0.35'
			)
			.from('.caracteristica-icon', { scale: 0, rotation: -45, duration: 0.5, ease: 'back.out(2)', stagger: 0.08 }, '-=0.6')
			.from('.caracteristica-valor', { autoAlpha: 0, x: -24, duration: 0.4, stagger: 0.09 }, '-=0.4');

		// Each check mark draws itself in as its row arrives.
		gsap.utils.toArray<SVGPolylineElement>('.caracteristica-check polyline').forEach((line, i) => {
			const len = line.getTotalLength();
			gsap.fromTo(
				line,
				{ strokeDasharray: len, strokeDashoffset: len },
				{
					strokeDashoffset: 0,
					duration: 0.45,
					ease: 'power2.out',
					delay: 0.9 + i * 0.09,
					scrollTrigger: { trigger: '#caracteristicas', start: 'top 70%', toggleActions: 'play none none none' },
				}
			);
		});

		initCardHoverLift(gsap.utils.toArray<HTMLElement>('.caracteristica-block'), {
			liftY: -6,
			iconSelector: '.caracteristica-icon, .caracteristica-logo',
		});

		return () => {};
	});
</script>
