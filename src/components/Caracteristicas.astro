---
const checkItems = ['Responsabilidad.', 'Confianza.', 'Compromiso.', 'Don de servicio.', 'Eficacia.'];
---

<section id="caracteristicas" class="py-20 sm:py-28 bg-brand-100">
	<div class="mx-auto max-w-6xl px-4">
		<div class="mx-auto max-w-3xl text-center">
			<span class="eyebrow-label">Por qué elegirnos</span>
			<h2 class="editorial-heading mb-12">Calidad, cercanía y compromiso en cada entrega</h2>
		</div>

		<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
		<div class="caracteristica-block lg:col-span-2 bg-cream-50 rounded-2xl p-6 shadow-lg">
			<h3 class="text-xl font-bold text-brand-800 mb-3">Nuestros Valores</h3>
			<p class="text-brand-900/80 mb-2">Para lograr nuestros objetivos, contamos con personal calificado que brinda:</p>
			<ul class="space-y-1">
				{checkItems.map((item) => (
					<li class="flex items-center gap-2 text-brand-900">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-gold-600 shrink-0">
							<polyline points="20 6 9 17 4 12"></polyline>
						</svg>
						{item}
					</li>
				))}
			</ul>
		</div>

		<div class="caracteristica-block bg-cream-50 rounded-2xl p-6 shadow-lg">
			<h3 class="text-xl font-bold text-brand-800 mb-3">Compra Fácil</h3>
			<p class="flex items-start gap-2 text-brand-900">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-gold-600 shrink-0 mt-1">
					<polyline points="20 6 9 17 4 12"></polyline>
				</svg>
				Contamos con canales de atención para que compres con seguridad.
			</p>
		</div>

		<div class="caracteristica-block bg-cream-50 rounded-2xl p-6 shadow-lg">
			<h3 class="text-xl font-bold text-brand-800 mb-3">Entrega a Domicilio</h3>
			<p class="flex items-start gap-2 text-brand-900">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-gold-600 shrink-0 mt-1">
					<polyline points="20 6 9 17 4 12"></polyline>
				</svg>
				En la ciudad Cali y Alrededores.
			</p>
		</div>

		<div class="caracteristica-block bg-cream-50 rounded-2xl p-6 shadow-lg">
			<h3 class="text-xl font-bold text-brand-800 mb-3">Personal Calificado</h3>
			<p class="flex items-start gap-2 text-brand-900">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-gold-600 shrink-0 mt-1">
					<polyline points="20 6 9 17 4 12"></polyline>
				</svg>
				Somos expertos en la preparación de Lechona con nuestra propia receta.
			</p>
		</div>
		</div>
	</div>
</section>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	const mm = gsap.matchMedia();

	mm.add({ reduceMotion: '(prefers-reduced-motion: reduce)', okMotion: '(prefers-reduced-motion: no-preference)' }, (context) => {
		const { reduceMotion } = context.conditions as { reduceMotion: boolean };

		gsap.from('.caracteristica-block', {
			autoAlpha: reduceMotion ? 1 : 0,
			y: reduceMotion ? 0 : 40,
			scale: reduceMotion ? 1 : 0.85,
			duration: reduceMotion ? 0 : 0.7,
			ease: 'back.out(1.7)',
			stagger: reduceMotion ? 0 : 0.15,
			scrollTrigger: {
				trigger: '#caracteristicas',
				start: 'top 80%',
				toggleActions: 'play none none reverse',
			},
		});

		return () => {};
	});
</script>
