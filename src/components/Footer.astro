---
import { PHONE_DISPLAY, PHONE_TEL_HREF, WHATSAPP_URL } from '../lib/contact';

const year = new Date().getFullYear();

const siteLinks = [
	{ label: 'Inicio', href: '#hero' },
	{ label: 'Quiénes Somos', href: '#somos-chancho' },
	{ label: 'Nuestros Productos', href: '#nuestros-productos' },
	{ label: 'Ubícanos', href: '#ubicanos' },
];

const legalLinks = [
	{ label: 'Términos y Condiciones', href: '/terminos' },
	{ label: 'Política de Privacidad', href: '/politica-de-privacidad' },
];
---

<footer class="footer-section bg-brand-900 text-cream-50">
	<div class="mx-auto max-w-6xl px-4 py-14">
		<div class="grid gap-10 text-center sm:text-left md:grid-cols-4">
			<div class="md:col-span-2">
				<a href="#hero" class="inline-flex items-center gap-3">
					<img src="/media/logoChanchoLechon3.webp" alt="Logo de Lechonería Chancho el Lechón" class="h-14 w-auto" />
					<span class="text-left text-lg font-extrabold leading-tight">
						Lechonería<br />
						<span class="text-gold-400">Chancho el Lechón</span>
					</span>
				</a>
				<p class="mt-4 max-w-sm text-sm leading-relaxed text-cream-50/70 sm:mx-0">
					La mejor lechona de Cali, con cuero súper crocante y sazón de casa. ¡La del 7 de Agosto, desde 2019!
				</p>
			</div>

			<div>
				<h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-gold-400">Explora</h3>
				<ul class="space-y-2 text-sm">
					{
						siteLinks.map((l) => (
							<li>
								<a href={l.href} class="text-cream-50/80 transition-colors hover:text-gold-400">
									{l.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<div>
				<h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-gold-400">Contacto</h3>
				<ul class="space-y-2 text-sm text-cream-50/80">
					<li>Barrio 7 de Agosto</li>
					<li>Diag 15 #71A-58, Cali</li>
					<li>
						<a href={PHONE_TEL_HREF} class="transition-colors hover:text-gold-400">{PHONE_DISPLAY}</a>
					</li>
					<li>
						<a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-gold-400">
							WhatsApp
						</a>
					</li>
				</ul>
			</div>
		</div>

		<div class="mt-12 flex flex-col items-center gap-3 border-t border-cream-50/10 pt-6 text-sm text-cream-50/60 sm:flex-row sm:justify-between">
			<p>© {year} Lechonería Chancho el Lechón. Todos los derechos reservados.</p>
			<ul class="flex flex-wrap items-center justify-center gap-x-6 gap-y-1">
				{
					legalLinks.map((l) => (
						<li>
							<a href={l.href} class="transition-colors hover:text-gold-400">
								{l.label}
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</footer>
