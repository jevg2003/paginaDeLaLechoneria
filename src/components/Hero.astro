---
import { Image } from 'astro:assets';
import cajasImg from '../assets/images/racion-cojin-hero-hd.webp';
import lechonaAbierta from '../assets/images/lechona-abierta-cutout.png';
import pernil from '../assets/images/pernil-cutout.png';
import lechonaMixta from '../assets/images/lechona-mixta-cutout.png';
import cojin from '../assets/images/cojin-cutout.png';
import cerditoCuero from '../assets/images/pendiente-decorativo-cerdo-cuero.png';

const rotationImages = [
	{ src: lechonaAbierta, alt: 'Lechona abierta, Chancho el Lechón', framed: false, zoom: 1.25 },
	{ src: lechonaMixta, alt: 'Lechona mixta, Chancho el Lechón', framed: false, zoom: 1 },
	{ src: cojin, alt: 'Cojín de lechona, Chancho el Lechón', framed: false, zoom: 1.3 },
	{ src: pernil, alt: 'Pernil de lechona, Chancho el Lechón', framed: false, zoom: 1.15 },
	{ src: cerditoCuero, alt: 'Chancho el Lechón', framed: false, zoom: 1.1 },
	{ src: cajasImg, alt: 'Cajas de lechona listas para entrega, Chancho el Lechón', framed: true, zoom: 1 },
];
---

<div id="hero-loader" class="fixed inset-0 z-[80] flex flex-col items-center justify-center gap-5 bg-brand-600">
	<img src="/media/logoChanchoLechon3.webp" alt="" class="hero-loader-logo h-28 w-auto drop-shadow-xl" />
	<div class="flex gap-2" aria-hidden="true">
		<span class="hero-loader-dot size-3 rounded-full bg-gold-400"></span>
		<span class="hero-loader-dot size-3 rounded-full bg-gold-400"></span>
		<span class="hero-loader-dot size-3 rounded-full bg-gold-400"></span>
	</div>
	<span class="sr-only">Cargando…</span>
</div>

<section id="hero" class="hero-section relative isolate min-h-screen overflow-hidden bg-brand-600 text-cream-50">
	<div class="hero-particles pointer-events-none absolute inset-0" aria-hidden="true">
		<span class="hero-particle hero-particle-1 absolute left-[12%] top-[22%] size-16 rounded-full bg-gold-300/30 blur-2xl"></span>
		<span class="hero-particle hero-particle-2 absolute right-[15%] top-[35%] size-10 rounded-full bg-cream-50/20 blur-xl"></span>
		<span class="hero-particle hero-particle-3 absolute bottom-[20%] left-[20%] size-8 rounded-full bg-gold-400/25 blur-lg"></span>
	</div>

	<div class="hero-glow pointer-events-none absolute right-10 top-1/2 hidden h-96 w-96 -translate-y-1/2 rounded-full bg-gold-400/30 blur-3xl lg:block"></div>

	<div class="hero-content relative z-10 mx-auto flex min-h-screen max-w-7xl flex-col items-center justify-center gap-3 px-4 pb-24 pt-24 text-center">

		<div class="hero-heading flex items-center justify-center gap-4 sm:gap-7">
			<div class="hero-logo-wrap shrink-0">
				<img
					src="/media/logoChanchoLechon3.webp"
					alt="Logo de Lechonería Chancho el Lechón"
					class="hero-logo h-24 w-auto drop-shadow-2xl sm:h-32 lg:h-40"
				/>
			</div>

			<h1 class="hero-title text-left font-extrabold leading-[1.05] tracking-tight">
				<span class="hero-title-line block text-2xl sm:text-4xl lg:text-5xl">Lechonería</span>
				<span class="hero-title-line block text-3xl text-gold-400 sm:text-5xl lg:text-6xl">Chancho el Lechón</span>
				<span class="hero-title-line mt-1 block text-lg font-bold text-cream-50/90 sm:text-xl lg:text-2xl">¡La del 7 de Agosto!</span>
			</h1>
		</div>

		<div class="hero-pedestal-wrap relative mt-4 flex justify-center" tabindex="-1">
			<div
				class="hero-badge absolute -top-4 right-0 z-50 flex size-20 cursor-grab touch-none select-none items-center justify-center rounded-full border-2 border-gold-400 bg-brand-900/80 text-center text-xs font-bold uppercase leading-tight text-gold-400 shadow-xl active:cursor-grabbing sm:size-24 sm:text-sm"
				aria-hidden="true"
			>
				<span>Desde<br />2019</span>
			</div>

			<div class="hero-pedestal relative h-56 w-[20rem] sm:h-72 sm:w-[30rem] lg:h-80 lg:w-[38rem]">
				<div class="hero-pedestal-surface absolute inset-x-8 bottom-0 h-2/3 rounded-[50%] bg-gradient-to-b from-brand-700 to-brand-800 shadow-2xl sm:inset-x-16"></div>

				<div class="hero-cutout-stack absolute inset-0">
					{
						rotationImages.map((img, i) => (
							<Image
								src={img.src}
								alt={img.alt}
								class={
									img.framed
										? 'hero-cutout absolute inset-x-8 top-0 bottom-4 mx-auto h-auto max-h-full w-auto rounded-[2rem] object-cover opacity-0 shadow-2xl ring-2 ring-gold-400/40'
										: 'hero-cutout absolute inset-0 h-full w-full object-contain opacity-0 drop-shadow-2xl'
								}
								data-cutout-index={i}
								data-zoom={img.zoom}
								widths={[400, 640, 900]}
								sizes="(min-width: 1024px) 608px, 480px"
								format="webp"
								loading={i === 0 ? 'eager' : 'lazy'}
								fetchpriority={i === 0 ? 'high' : undefined}
							/>
						))
					}
				</div>
			</div>
		</div>

		<a href="#final" class="hero-cta mt-1">
			<button class="cursor-pointer rounded-full bg-gold-500 px-8 py-4 text-lg font-bold text-brand-900 shadow-lg transition-transform hover:scale-105 hover:bg-gold-600">
				¡Realiza tu Pedido!
			</button>
		</a>
	</div>

	<button
		id="hero-rotation-toggle"
		type="button"
		aria-pressed="false"
		aria-label="Pausar rotación automática de imágenes"
		class="hero-rotation-toggle absolute right-4 top-6 z-20 hidden size-9 items-center justify-center rounded-full border border-cream-50/30 bg-brand-900/50 text-cream-50 backdrop-blur-sm transition-colors hover:bg-brand-900/80 sm:flex"
	>
		<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="hero-icon-pause size-4">
			<rect x="6" y="5" width="4" height="14" rx="1"></rect>
			<rect x="14" y="5" width="4" height="14" rx="1"></rect>
		</svg>
		<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="hero-icon-play hidden size-4">
			<path d="M8 5v14l11-7z"></path>
		</svg>
	</button>

	<a
		href="#somos-chancho"
		class="hero-scroll-indicator absolute bottom-6 left-1/2 z-20 flex -translate-x-1/2 flex-col items-center gap-1 text-cream-50/80 transition-colors hover:text-gold-400"
	>
		<span class="text-xs font-medium uppercase tracking-widest">Descubre más</span>
		<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hero-scroll-chevron size-5">
			<polyline points="6 9 12 15 18 9"></polyline>
		</svg>
	</a>
</section>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	import { Draggable } from 'gsap/Draggable';
	import { InertiaPlugin } from 'gsap/InertiaPlugin';

	gsap.registerPlugin(ScrollTrigger, Draggable, InertiaPlugin);

	const mm = gsap.matchMedia();

	const cutouts = gsap.utils.toArray<HTMLElement>('.hero-cutout');
	const ROTATION_INTERVAL = 4;

	// --- Page loader: covers the hero until assets are ready so half-loaded
	// cutouts never flash stacked in the middle. Falls back after 3.5s.
	const loader = document.getElementById('hero-loader');
	const loaderDots = gsap.to('.hero-loader-dot', {
		y: -10,
		duration: 0.4,
		yoyo: true,
		repeat: -1,
		stagger: 0.12,
		ease: 'sine.inOut',
	});
	const loaderPulse = gsap.to('.hero-loader-logo', {
		scale: 1.08,
		duration: 0.8,
		yoyo: true,
		repeat: -1,
		ease: 'sine.inOut',
	});

	let pageReady = false;
	const readyCallbacks: Array<() => void> = [];
	function whenReady(cb: () => void) {
		pageReady ? cb() : readyCallbacks.push(cb);
	}
	function finishLoading() {
		if (pageReady) return;
		pageReady = true;
		loaderDots.kill();
		loaderPulse.kill();
		gsap.to(loader, {
			autoAlpha: 0,
			scale: 1.06,
			duration: 0.45,
			ease: 'power2.inOut',
			onComplete: () => loader?.remove(),
		});
		readyCallbacks.forEach((cb) => cb());
	}
	if (document.readyState === 'complete') {
		finishLoading();
	} else {
		window.addEventListener('load', finishLoading);
		setTimeout(finishLoading, 3500);
	}

	let currentIndex = 0;
	let rotationTimer: gsap.core.Tween | null = null;
	let manuallyPaused = false;
	let hoverPaused = false;
	let offscreen = false;
	const isPaused = () => manuallyPaused || hoverPaused || offscreen || document.hidden;

	// Carousel slots relative to the active image: center stage, dimmed
	// side previews, and a hidden "backstage" slot new images emerge from.
	const SLOTS = {
		center: { xPercent: 0, scale: 1, autoAlpha: 1, zIndex: 30 },
		right: { xPercent: 74, scale: 0.4, autoAlpha: 0.35, zIndex: 10 },
		left: { xPercent: -74, scale: 0.4, autoAlpha: 0.35, zIndex: 10 },
		back: { xPercent: 0, scale: 0.3, autoAlpha: 0, zIndex: 0 },
	};

	function slotFor(i: number, active: number) {
		const n = cutouts.length;
		const rel = (i - active + n) % n;
		if (rel === 0) return SLOTS.center;
		if (rel === 1) return SLOTS.right;
		if (rel === n - 1) return SLOTS.left;
		return SLOTS.back;
	}

	function layout(active: number, duration: number, ease: string) {
		cutouts.forEach((el, i) => {
			const slot = slotFor(i, active);
			const zoom = parseFloat(el.dataset.zoom || '1');
			gsap.to(el, { ...slot, scale: slot.scale * zoom, duration, ease, overwrite: 'auto' });
		});
		currentIndex = active;
	}

	function startRotation(duration: number, ease: string) {
		rotationTimer?.kill();
		layout(currentIndex, 0, 'none');
		rotationTimer = gsap.to(
			{},
			{
				duration: ROTATION_INTERVAL,
				repeat: -1,
				onRepeat: () => {
					if (isPaused() || cutouts.length < 2) return;
					layout((currentIndex + 1) % cutouts.length, duration, ease);
				},
			}
		);
	}

	// Pause control (WCAG 2.2.2) — works regardless of reduced-motion branch.
	const toggleBtn = document.getElementById('hero-rotation-toggle');
	const iconPause = document.querySelector('.hero-icon-pause');
	const iconPlay = document.querySelector('.hero-icon-play');

	toggleBtn?.addEventListener('click', () => {
		manuallyPaused = !manuallyPaused;
		toggleBtn.setAttribute('aria-pressed', String(manuallyPaused));
		toggleBtn.setAttribute(
			'aria-label',
			manuallyPaused ? 'Reanudar rotación automática de imágenes' : 'Pausar rotación automática de imágenes'
		);
		iconPause?.classList.toggle('hidden', manuallyPaused);
		iconPlay?.classList.toggle('hidden', !manuallyPaused);
	});

	// Swipe / drag to advance the carousel manually (mouse or touch).
	const stack = document.querySelector<HTMLElement>('.hero-cutout-stack');
	if (stack) {
		stack.style.touchAction = 'pan-y';
		stack.style.cursor = 'grab';
		stack.style.userSelect = 'none';
		// Native image dragging swallows the pointerup that ends our swipe.
		stack.addEventListener('dragstart', (e) => e.preventDefault());
		let dragStartX: number | null = null;

		stack.addEventListener('pointerdown', (e) => {
			dragStartX = e.clientX;
		});
		window.addEventListener('pointerup', (e) => {
			if (dragStartX === null) return;
			const dx = e.clientX - dragStartX;
			dragStartX = null;
			if (Math.abs(dx) < 40 || cutouts.length < 2) return;
			const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const n = cutouts.length;
			const next = dx < 0 ? (currentIndex + 1) % n : (currentIndex - 1 + n) % n;
			layout(next, reduce ? 0.15 : 0.6, reduce ? 'none' : 'power2.out');
			// Restart the auto-rotation clock so the manual pick gets full stage time.
			rotationTimer?.restart(true);
		});
	}

	const pedestalWrap = document.querySelector('.hero-pedestal-wrap');
	pedestalWrap?.addEventListener('mouseenter', () => {
		hoverPaused = true;
	});
	pedestalWrap?.addEventListener('mouseleave', () => {
		hoverPaused = false;
	});
	pedestalWrap?.addEventListener('focusin', () => {
		hoverPaused = true;
	});
	pedestalWrap?.addEventListener('focusout', () => {
		hoverPaused = false;
	});

	mm.add(
		{
			reduceMotion: '(prefers-reduced-motion: reduce)',
			okMotion: '(prefers-reduced-motion: no-preference)',
		},
		(context) => {
			const { reduceMotion } = context.conditions as { reduceMotion: boolean };

			currentIndex = 0;
			layout(0, 0, 'none');

			if (reduceMotion) {
				// Rotation MUST keep advancing through all 4 images under reduced
				// motion — only the crossfade tween itself is simplified to an
				// instant/short opacity swap (no transform/slide/scale).
				gsap.set('.hero-logo, .hero-title-line, .hero-cta, .hero-badge, .hero-scroll-indicator', {
					autoAlpha: 0,
				});
				gsap.to('.hero-logo, .hero-title-line, .hero-cta, .hero-badge, .hero-scroll-indicator', {
					autoAlpha: 1,
					duration: 0.7,
					stagger: 0.15,
					ease: 'power1.out',
				});
				gsap.set('.hero-particles', { autoAlpha: 1 });
				startRotation(0.15, 'none');

				// Gentle continuous ambient motion (opacity-only, no transform/parallax)
				// so there's always something visibly alive, not just a one-time fade.
				gsap.to('.hero-glow', {
					opacity: 0.55,
					duration: 3.5,
					yoyo: true,
					repeat: -1,
					ease: 'sine.inOut',
				});

				return () => {
					rotationTimer?.kill();
				};
			}

			// Entrance timeline — plays once the loader clears, never over it.
			// Hide everything up front so nothing flashes while waiting.
			gsap.set('.hero-logo, .hero-title-line, .hero-pedestal-wrap, .hero-badge, .hero-cta', { autoAlpha: 0 });
			const tl = gsap.timeline({ defaults: { ease: 'power3.out' }, paused: true, delay: 0.15 });

			// Refined reveal: the logo resolves out of a soft blur while the
			// name slides in beside it, line by line.
			tl.fromTo(
				'.hero-logo',
				{ autoAlpha: 0, x: -50, scale: 0.85, filter: 'blur(12px)' },
				{ autoAlpha: 1, x: 0, scale: 1, filter: 'blur(0px)', duration: 1.1, ease: 'power3.out' }
			)
				.fromTo(
					'.hero-title-line',
					{ autoAlpha: 0, x: 60 },
					{ autoAlpha: 1, x: 0, duration: 0.9, stagger: 0.14, ease: 'power4.out' },
					'-=0.75'
				)
				.fromTo(
					'.hero-pedestal-wrap',
					{ autoAlpha: 0, y: 40, scale: 0.9 },
					{ autoAlpha: 1, y: 0, scale: 1, duration: 0.8, ease: 'back.out(1.6)' },
					'-=0.4'
				)
				.fromTo(
					'.hero-badge',
					{ autoAlpha: 0, scale: 0.5, rotation: -20 },
					{ autoAlpha: 1, scale: 1, rotation: 0, duration: 0.6, ease: 'back.out(1.9)' },
					'-=0.4'
				)
				.fromTo(
					'.hero-cta',
					{ autoAlpha: 0, y: 30, scale: 0.7 },
					{ autoAlpha: 1, y: 0, scale: 1, duration: 0.7, ease: 'back.out(1.9)' },
					'-=0.3'
				);

			whenReady(() => tl.play());

			startRotation(0.8, 'power2.inOut');

			const ambient: gsap.core.Tween[] = [];

			// Ambient badge float
			const badgeFloat = gsap.to('.hero-badge', {
				y: '+=8',
				rotation: 4,
				duration: 2.4,
				yoyo: true,
				repeat: -1,
				ease: 'sine.inOut',
				delay: 2.2,
			});
			ambient.push(badgeFloat);

			// The badge is a toy: grab it, throw it around the hero, and it
			// lands with a springy bounce.
			Draggable.create('.hero-badge', {
				type: 'x,y',
				bounds: '.hero-section',
				inertia: true,
				edgeResistance: 0.75,
				onPress() {
					badgeFloat.kill();
					gsap.to(this.target, { scale: 1.15, duration: 0.2, ease: 'power2.out', overwrite: 'auto' });
				},
				onRelease() {
					gsap.to(this.target, { scale: 1, duration: 0.6, ease: 'elastic.out(1, 0.35)' });
				},
				onThrowComplete() {
					gsap.fromTo(
						this.target,
						{ scaleX: 1.25, scaleY: 0.8 },
						{ scaleX: 1, scaleY: 1, duration: 0.7, ease: 'elastic.out(1, 0.3)' }
					);
				},
			});

			// Ambient particle drift (steam/spice feel)
			gsap.utils.toArray<HTMLElement>('.hero-particle').forEach((particle, i) => {
				ambient.push(
					gsap.to(particle, {
						y: '+=18',
						x: i % 2 === 0 ? '+=10' : '-=10',
						opacity: 0.6,
						duration: 3 + i * 0.6,
						yoyo: true,
						repeat: -1,
						ease: 'sine.inOut',
						delay: i * 0.4,
					})
				);
			});

			ambient.push(
				gsap.to('.hero-glow', {
					scale: 1.3,
					opacity: 0.55,
					duration: 3,
					yoyo: true,
					repeat: -1,
					ease: 'sine.inOut',
				})
			);

			// Pause everything the moment the hero leaves the viewport so the
			// browser isn't animating things nobody can see.
			ScrollTrigger.create({
				trigger: '#hero',
				start: 'top bottom',
				end: 'bottom top',
				onToggle: (self) => {
					offscreen = !self.isActive;
					ambient.forEach((t) => (self.isActive ? t.play() : t.pause()));
				},
			});

			// Second pin+scrub: Hero exit transition into the next section.
			// Disabled below the mobile breakpoint to avoid stacking two
			// consecutive scroll-jacked pins (Hero-exit + Proceso) on small
			// screens/low-power devices.
			const isMobile = window.matchMedia('(max-width: 767px)').matches;

			if (!isMobile) {
				gsap.timeline({
					scrollTrigger: {
						trigger: '#hero',
						start: 'top top',
						end: '+=800',
						pin: true,
						scrub: true,
					},
				})
					.to('.hero-pedestal-wrap', { scale: 0.75, y: -30, duration: 1, ease: 'none' }, 0)
					.to(
						// The badge is deliberately NOT in this list: exit-fading it
						// fought its float/drag tweens and could leave it invisible
						// after scrolling back or reloading mid-page.
						'.hero-title, .hero-logo-wrap, .hero-cta, .hero-rotation-toggle, .hero-scroll-indicator, .hero-particles',
						{ autoAlpha: 0, y: -60, duration: 0.8, ease: 'none' },
						0
					);
			}

			return () => {
				rotationTimer?.kill();
			};
		}
	);
</script>
