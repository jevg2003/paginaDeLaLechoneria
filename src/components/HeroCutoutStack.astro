---
import { Image } from 'astro:assets';
import { heroCutouts } from '../data/heroCutouts';
---

<div class="hero-pedestal relative h-56 w-[20rem] sm:h-72 sm:w-[30rem] lg:h-80 lg:w-[38rem]">
	<div class="hero-pedestal-surface absolute inset-x-8 bottom-0 h-2/3 rounded-[50%] bg-gradient-to-b from-brand-700 to-brand-800 shadow-2xl sm:inset-x-16"></div>

	<div class="hero-cutout-stack absolute inset-0">
		{
			heroCutouts.map((img, i) => (
				<Image
					src={img.src}
					alt={img.alt}
					class={
						// Slide 0 stays visible in the raw HTML: it's the center
						// slide anyway, and hiding it gated LCP behind the loader.
						img.framed
							? `hero-cutout absolute inset-x-12 top-3 bottom-8 mx-auto h-auto max-h-full w-auto rounded-[2rem] object-cover shadow-2xl ring-2 ring-gold-400/40 ${i === 0 ? '' : 'opacity-0'}`
							: `hero-cutout absolute inset-0 h-full w-full object-contain drop-shadow-2xl ${i === 0 ? '' : 'opacity-0'}`
					}
					data-cutout-index={i}
					data-zoom={img.zoom}
					widths={[400, 640, 900]}
					sizes="(min-width: 1024px) 608px, 480px"
					format="webp"
					loading={i === 0 ? 'eager' : 'lazy'}
					decoding="async"
					fetchpriority={i === 0 ? 'high' : 'low'}
				/>
			))
		}
	</div>
</div>
