---
import { PHONE_E164 } from '../lib/contact';
import { products } from '../data/products';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';
import ProductCard from './ProductCard.astro';

const waNumber = PHONE_E164.replace('+', '');
---

<section id="nuestros-productos" class="py-16 sm:py-20 bg-cream-50">
	<div class="w-full px-4 sm:px-8">
		<div class="mx-auto max-w-3xl text-center">
			<h2 class="editorial-heading mb-2">¡Nuestros Productos!</h2>
			<p class="mb-10 text-lg font-semibold text-brand-600">
				Toca cada foto para conocer el producto y pedir tu cotización
			</p>
		</div>

		<div class="productos-grid grid grid-cols-2 gap-3 md:grid-cols-3 lg:gap-4">
			{products.map((product) => <ProductCard product={product} />)}
		</div>
	</div>
</section>

<div
	id="producto-modal"
	class="fixed inset-0 z-[60] hidden items-center justify-center bg-brand-900/80 p-4 backdrop-blur-sm"
	role="dialog"
	aria-modal="true"
	aria-labelledby="producto-modal-title"
>
	<div class="producto-modal-box relative w-full max-w-3xl overflow-hidden rounded-3xl bg-cream-50 shadow-2xl">
		<button
			id="producto-modal-close"
			type="button"
			aria-label="Cerrar"
			class="absolute right-4 top-4 z-10 flex size-10 items-center justify-center rounded-full bg-brand-900/70 text-xl font-bold text-cream-50 transition-colors hover:bg-brand-900"
		>
			×
		</button>
		<div class="producto-modal-media h-64 w-full sm:h-80"></div>
		<div class="producto-modal-body p-6 sm:p-8">
			<h3 id="producto-modal-title" class="text-2xl font-extrabold text-brand-800 sm:text-3xl"></h3>
			<span class="producto-modal-bar mt-2 block h-1 w-16 origin-left rounded bg-gold-500"></span>
			<p class="producto-modal-info mt-3 leading-relaxed text-brand-900/80"></p>
			<a
				href={`https://wa.me/${waNumber}`}
				class="producto-modal-cta mt-6 inline-flex items-center gap-2 rounded-full bg-gold-500 px-8 py-4 text-lg font-bold text-brand-900 shadow-lg transition-transform hover:scale-105 hover:bg-gold-600"
				target="_blank"
				rel="noopener noreferrer"
			>
				<WhatsAppIcon class="size-6" />
				Cotizar
			</a>
		</div>
	</div>
</div>

<script>
	import { initProductModal } from '../lib/productModal';

	const waNumber = document.querySelector<HTMLAnchorElement>('.producto-modal-cta')!.href.split('/').pop()!;
	initProductModal(waNumber);
</script>
