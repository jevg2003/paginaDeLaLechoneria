---
import { WHATSAPP_URL, PHONE_DISPLAY } from '../lib/contact';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';

const channels = [
	{
		name: 'WhatsApp',
		handle: PHONE_DISPLAY,
		action: 'Escríbenos',
		href: WHATSAPP_URL,
		chip: 'bg-green-500',
		icon: 'whatsapp',
	},
	{
		name: 'Facebook',
		handle: 'Chancho el Lechón',
		action: 'Síguenos',
		href: 'https://www.facebook.com/franciaelena.gonzalez',
		chip: 'bg-blue-600',
		icon: 'facebook',
	},
	{
		name: 'Instagram',
		handle: '@chanchoellechon',
		action: 'Síguenos',
		href: 'https://www.instagram.com/chanchoellechon/',
		chip: 'bg-gradient-to-br from-pink-500 via-red-500 to-yellow-400',
		icon: 'instagram',
	},
];
---

<section id="redes" class="bg-cream-50 py-16 sm:py-24">
	<div class="mx-auto max-w-6xl px-4">
		<div class="mx-auto max-w-3xl text-center">
			<h2 class="editorial-heading mb-2">Síguenos y Contáctanos</h2>
			<p class="mb-10 text-lg font-semibold text-brand-600">Elige tu canal favorito y hablemos</p>
		</div>

		<div class="grid gap-4 sm:grid-cols-3 lg:gap-6">
			{
				channels.map((c) => (
					<a
						href={c.href}
						target="_blank"
						rel="noopener noreferrer"
						class="red-card group relative flex items-center gap-4 overflow-hidden rounded-3xl bg-white p-5 shadow-lg ring-1 ring-brand-900/5 will-change-transform sm:flex-col sm:items-center sm:gap-3 sm:p-8 sm:text-center"
					>
						<span class="red-spotlight pointer-events-none absolute inset-0 opacity-0" aria-hidden="true" />
						<span class={`red-icon flex size-14 shrink-0 items-center justify-center rounded-2xl text-white shadow-md sm:size-16 ${c.chip}`}>
							{c.icon === 'whatsapp' && <WhatsAppIcon class="size-8" detailed />}
							{c.icon === 'facebook' && (
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-8">
									<path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.91h2.54V9.85c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.44 2.91h-2.34V22c4.78-.76 8.44-4.92 8.44-9.94Z" />
								</svg>
							)}
							{c.icon === 'instagram' && (
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-8">
									<path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23a3.7 3.7 0 0 1-.9 1.38 3.7 3.7 0 0 1-1.38.9c-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41 1.27-.06 1.65-.07 4.85-.07ZM12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63a5.87 5.87 0 0 0-2.12 1.38A5.87 5.87 0 0 0 .64 4.13C.34 4.9.14 5.78.08 7.05.02 8.33 0 8.74 0 12s.02 3.67.08 4.95c.06 1.27.26 2.15.56 2.91.31.8.72 1.47 1.38 2.13.66.66 1.34 1.07 2.13 1.38.76.3 1.64.5 2.91.56C8.33 23.98 8.74 24 12 24s3.67-.02 4.95-.08c1.27-.06 2.15-.26 2.91-.56a5.87 5.87 0 0 0 2.13-1.38 5.87 5.87 0 0 0 1.38-2.13c.3-.76.5-1.64.56-2.91.06-1.28.08-1.69.08-4.95s-.02-3.67-.08-4.95c-.06-1.27-.26-2.15-.56-2.91a5.87 5.87 0 0 0-1.38-2.13A5.87 5.87 0 0 0 19.86.63c-.76-.3-1.64-.5-2.91-.56C15.67.02 15.26 0 12 0Zm0 5.84A6.16 6.16 0 1 0 12 18.16 6.16 6.16 0 0 0 12 5.84Zm0 10.16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm6.41-10.4a1.44 1.44 0 1 1-2.88 0 1.44 1.44 0 0 1 2.88 0Z" />
								</svg>
							)}
						</span>
						<span class="flex min-w-0 flex-col sm:items-center">
							<span class="text-lg font-extrabold text-brand-800">{c.name}</span>
							<span class="truncate text-sm text-brand-900/60">{c.handle}</span>
							<span class="mt-1 inline-flex items-center gap-1 text-sm font-bold text-gold-600 transition-transform group-hover:translate-x-1 sm:mt-3">
								{c.action}
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4">
									<line x1="5" y1="12" x2="19" y2="12" />
									<polyline points="12 5 19 12 12 19" />
								</svg>
							</span>
						</span>
					</a>
				))
			}
		</div>
	</div>
</section>

<style>
	.red-card {
		transition: box-shadow 0.35s cubic-bezier(0.22, 1, 0.36, 1);
	}
	.red-card:hover {
		box-shadow: 0 22px 40px -18px rgb(0 0 0 / 0.3);
	}
	/* Cursor-following spotlight, positioned via --mx/--my from JS. */
	.red-spotlight {
		background: radial-gradient(220px circle at var(--mx, 50%) var(--my, 50%), rgb(255 222 89 / 0.22), transparent 65%);
		transition: opacity 0.3s ease;
	}
	.red-card:hover .red-spotlight {
		opacity: 1;
	}
</style>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	import { initCardHoverLift } from '../lib/cardHoverLift';

	gsap.registerPlugin(ScrollTrigger);

	const mm = gsap.matchMedia();

	mm.add({ reduceMotion: '(prefers-reduced-motion: reduce)', okMotion: '(prefers-reduced-motion: no-preference)' }, (context) => {
		const { reduceMotion } = context.conditions as { reduceMotion: boolean };

		gsap.from('.red-card', {
			autoAlpha: 0,
			y: reduceMotion ? 0 : 50,
			duration: reduceMotion ? 0.3 : 0.7,
			ease: 'power3.out',
			stagger: reduceMotion ? 0.05 : 0.12,
			scrollTrigger: { trigger: '#redes', start: 'top 75%', toggleActions: 'play none none none' },
		});

		if (!reduceMotion) {
			gsap.from('.red-icon', {
				scale: 0,
				rotation: -30,
				duration: 0.5,
				ease: 'back.out(2)',
				stagger: 0.12,
				delay: 0.25,
				scrollTrigger: { trigger: '#redes', start: 'top 75%', toggleActions: 'play none none none' },
			});

			const cards = gsap.utils.toArray<HTMLElement>('.red-card');
			initCardHoverLift(cards, { liftY: -6, iconSelector: '.red-icon', leaveDuration: 0.5 });

			// 3D tilt toward the cursor + spotlight tracking, layered on top of
			// the shared hover lift above.
			cards.forEach((card) => {
				gsap.set(card, { transformPerspective: 700 });
				const rx = gsap.quickTo(card, 'rotationX', { duration: 0.4, ease: 'power2.out' });
				const ry = gsap.quickTo(card, 'rotationY', { duration: 0.4, ease: 'power2.out' });

				card.addEventListener('mousemove', (e) => {
					const r = card.getBoundingClientRect();
					const px = (e.clientX - r.left) / r.width;
					const py = (e.clientY - r.top) / r.height;
					card.style.setProperty('--mx', `${px * 100}%`);
					card.style.setProperty('--my', `${py * 100}%`);
					rx((0.5 - py) * 10);
					ry((px - 0.5) * 10);
				});
				card.addEventListener('mouseleave', () => {
					rx(0);
					ry(0);
				});
			});
		}

		return () => {};
	});
</script>
