---
import { WHATSAPP_URL } from '../lib/contact';
---

<section id="redes" class="py-16 sm:py-20 bg-cream-50">
	<div class="mx-auto max-w-6xl px-4 flex flex-col items-center gap-8">
		<h2 class="text-3xl sm:text-4xl font-extrabold text-brand-800">Síguenos y Contáctanos</h2>
		<div class="flex items-center gap-8">
			<a
				href={WHATSAPP_URL}
				target="_blank"
				rel="noopener noreferrer"
				aria-label="WhatsApp"
				class="flex items-center justify-center size-16 rounded-full bg-green-500 hover:bg-green-600 text-white shadow-lg transition-colors"
			>
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" fill="currentColor" class="size-8">
					<path d="M16.004 3C9.377 3 4 8.377 4 15.004c0 2.523.703 4.883 1.921 6.898L4 29l7.264-1.9a11.94 11.94 0 0 0 4.74.973h.001c6.626 0 12.003-5.377 12.003-12.004C28.008 8.377 22.63 3 16.004 3Zm7.052 17.03c-.297.836-1.47 1.53-2.417 1.73-.643.135-1.483.243-4.31-.926-3.616-1.494-5.945-5.163-6.128-5.402-.176-.24-1.472-1.96-1.472-3.738 0-1.777.933-2.65 1.264-3.014.297-.325.663-.406.884-.406.221 0 .441.002.634.012.204.01.478-.077.747.57.297.713.884 2.316.96 2.485.078.169.13.365.026.585-.1.22-.156.357-.31.55-.156.194-.328.433-.469.582-.156.169-.32.352-.137.688.183.336.812 1.343 1.744 2.176 1.198 1.07 2.208 1.4 2.545 1.56.336.16.533.135.73-.08.196-.216.833-.972 1.055-1.306.222-.335.446-.28.75-.168.305.11 1.93.912 2.261 1.078.331.166.552.248.632.386.08.14.08.804-.216 1.639Z" />
				</svg>
			</a>
			<a
				href="https://www.facebook.com/franciaelena.gonzalez"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Facebook"
				class="flex items-center justify-center size-16 rounded-full bg-blue-600 hover:bg-blue-700 text-white shadow-lg transition-colors"
			>
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-8">
					<path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.91h2.54V9.85c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.44 2.91h-2.34V22c4.78-.76 8.44-4.92 8.44-9.94Z" />
				</svg>
			</a>
			<a
				href="https://www.instagram.com/chanchoellechon/"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Instagram"
				class="flex items-center justify-center size-16 rounded-full bg-gradient-to-br from-pink-500 via-red-500 to-yellow-400 hover:opacity-90 text-white shadow-lg transition-opacity"
			>
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-8">
					<path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23a3.7 3.7 0 0 1-.9 1.38 3.7 3.7 0 0 1-1.38.9c-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41 1.27-.06 1.65-.07 4.85-.07ZM12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63a5.87 5.87 0 0 0-2.12 1.38A5.87 5.87 0 0 0 .64 4.13C.34 4.9.14 5.78.08 7.05.02 8.33 0 8.74 0 12s.02 3.67.08 4.95c.06 1.27.26 2.15.56 2.91.31.8.72 1.47 1.38 2.13.66.66 1.34 1.07 2.13 1.38.76.3 1.64.5 2.91.56C8.33 23.98 8.74 24 12 24s3.67-.02 4.95-.08c1.27-.06 2.15-.26 2.91-.56a5.87 5.87 0 0 0 2.13-1.38 5.87 5.87 0 0 0 1.38-2.13c.3-.76.5-1.64.56-2.91.06-1.28.08-1.69.08-4.95s-.02-3.67-.08-4.95c-.06-1.27-.26-2.15-.56-2.91a5.87 5.87 0 0 0-1.38-2.13A5.87 5.87 0 0 0 19.86.63c-.76-.3-1.64-.5-2.91-.56C15.67.02 15.26 0 12 0Zm0 5.84A6.16 6.16 0 1 0 12 18.16 6.16 6.16 0 0 0 12 5.84Zm0 10.16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm6.41-10.4a1.44 1.44 0 1 1-2.88 0 1.44 1.44 0 0 1 2.88 0Z" />
				</svg>
			</a>
		</div>
	</div>
</section>
