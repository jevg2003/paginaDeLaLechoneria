---
import { PHONE_DISPLAY, PHONE_TEL_HREF, WHATSAPP_URL } from '../lib/contact';
---

<section id="ubicanos" class="relative overflow-hidden bg-brand-800 py-20 text-cream-50 sm:py-28">
	<div class="pointer-events-none absolute inset-0" aria-hidden="true">
		<span class="absolute -right-24 top-10 size-72 rounded-full bg-gold-400/10 blur-3xl"></span>
		<span class="absolute -left-20 bottom-16 size-64 rounded-full bg-brand-600/40 blur-3xl"></span>
	</div>

	<div class="relative mx-auto max-w-6xl px-4">
		<div class="mx-auto max-w-3xl text-center">
			<span class="eyebrow-label !text-gold-400">Visítanos</span>
			<h2 class="ubicanos-title mb-12 text-3xl font-extrabold leading-tight text-cream-50 sm:text-4xl lg:text-5xl">
				¡Ubícanos <span class="text-gold-400">en Cali!</span>
			</h2>
		</div>

		<div class="grid items-stretch gap-5 lg:grid-cols-5">
			<div class="ubicanos-info flex flex-col gap-4 lg:col-span-2">
				<div class="ubicanos-card rounded-3xl bg-gold-500 p-6 text-brand-900 shadow-xl">
					<div class="flex items-start gap-3">
						<span class="ubicanos-icon mt-1 flex size-11 shrink-0 items-center justify-center rounded-2xl bg-brand-900 text-gold-400">
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
								<path d="M12 2l2.9 6.26L21.5 9.27l-4.75 4.36L17.8 20 12 16.77 6.2 20l1.05-6.37L2.5 9.27l6.6-1.01L12 2z"></path>
							</svg>
						</span>
						<div>
							<h3 class="text-xl font-black">¡Lechona todos los fines de semana!</h3>
							<p class="mt-1 font-semibold leading-snug">
								Sacamos lechona SIEMPRE los sábados y domingos, hasta acabar existencias.{' '}
								<a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="underline decoration-brand-900 decoration-2 underline-offset-2">Escríbenos</a>{' '}o{' '}
								<a href={PHONE_TEL_HREF} class="underline decoration-brand-900 decoration-2 underline-offset-2">llámanos</a>{' '}antes de venir por la tuya.
							</p>
						</div>
					</div>
				</div>

				<div class="ubicanos-card rounded-3xl bg-cream-50 p-6 text-brand-900 shadow-xl">
					<div class="flex items-start gap-3">
						<span class="ubicanos-icon mt-1 flex size-11 shrink-0 items-center justify-center rounded-2xl bg-brand-600 text-gold-400">
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-6">
								<circle cx="12" cy="12" r="9"></circle>
								<polyline points="12 7 12 12 15 14"></polyline>
							</svg>
						</span>
						<div class="w-full">
							<h3 class="text-lg font-extrabold text-brand-800">Horario de atención y cotizaciones</h3>
							<ul class="mt-2 space-y-1 text-brand-900/70">
								<li class="flex justify-between gap-4"><span>Martes a viernes</span><span class="font-semibold text-brand-900">8:00 a.m. – 6:00 p.m.</span></li>
								<li class="flex justify-between gap-4"><span>Sábados y domingos</span><span class="font-semibold text-brand-900">9:00 a.m. – 8:00 p.m.</span></li>
								<li class="flex justify-between gap-4"><span>Lunes</span><span class="font-semibold text-brand-900">Cerrado</span></li>
							</ul>
						</div>
					</div>
				</div>

				<div class="ubicanos-card rounded-3xl bg-cream-50 p-6 text-brand-900 shadow-xl">
					<div class="flex items-start gap-3">
						<span class="ubicanos-icon mt-1 flex size-11 shrink-0 items-center justify-center rounded-2xl bg-brand-600 text-gold-400">
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-6">
								<path d="M12 21c-4-3.6-7-6.8-7-10.2A7 7 0 0 1 12 4a7 7 0 0 1 7 6.8c0 3.4-3 6.6-7 10.2z"></path>
								<circle cx="12" cy="10.5" r="2.5"></circle>
							</svg>
						</span>
						<div>
							<h3 class="text-lg font-extrabold text-brand-800">Nuestro local</h3>
							<p class="mt-1 text-brand-900/70">Barrio 7 de Agosto, Santiago de Cali.</p>
						</div>
					</div>
				</div>

				<div class="ubicanos-card rounded-3xl bg-cream-50 p-6 text-brand-900 shadow-xl">
					<div class="flex items-start gap-3">
						<span class="ubicanos-icon mt-1 flex size-11 shrink-0 items-center justify-center rounded-2xl bg-brand-600 text-gold-400">
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-6">
								<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"></path>
							</svg>
						</span>
						<div>
							<h3 class="text-lg font-extrabold text-brand-800">Pedidos y encargos</h3>
							<p class="mt-1 text-brand-900/70">
								Escríbenos por{' '}
								<a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="font-bold text-brand-600 underline decoration-gold-500 decoration-2 underline-offset-2 hover:text-brand-800">WhatsApp</a>{' '}o llámanos al{' '}
								<a href={PHONE_TEL_HREF} class="font-bold text-brand-600 underline decoration-gold-500 decoration-2 underline-offset-2 hover:text-brand-800">{PHONE_DISPLAY}</a>.
							</p>
							<p class="mt-2 text-brand-900/70">
								¿Quieres estar seguro antes de pedir? <span class="font-bold text-brand-800">Te damos una prueba de nuestro producto</span> — solo pregúntanos.
							</p>
						</div>
					</div>
				</div>
			</div>

			<div class="ubicanos-map overflow-hidden rounded-3xl shadow-2xl ring-2 ring-gold-400/20 lg:col-span-3">
				<iframe
					src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3982.608365770744!2d-76.48864115457685!3d3.44502800536179!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e30a7a704da3835%3A0x60b639078859074b!2sLechoneria%20Chancho%20el%20Lech%C3%B3n!5e0!3m2!1ses!2sco!4v1688500867815!5m2!1ses!2sco"
					width="100%"
					height="100%"
					class="min-h-[320px] lg:min-h-full"
					style="border:0;"
					allowfullscreen
					loading="lazy"
					referrerpolicy="no-referrer-when-downgrade"
					title="Mapa de Lechonería Chancho el Lechón en Google Maps"
				></iframe>
			</div>
		</div>
	</div>
</section>

<style>
	.ubicanos-card {
		transition:
			transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
			box-shadow 0.35s cubic-bezier(0.22, 1, 0.36, 1);
	}
	.ubicanos-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 20px 36px -18px rgb(0 0 0 / 0.45);
	}
</style>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	const mm = gsap.matchMedia();

	mm.add({ reduceMotion: '(prefers-reduced-motion: reduce)', okMotion: '(prefers-reduced-motion: no-preference)' }, (context) => {
		const { reduceMotion } = context.conditions as { reduceMotion: boolean };

		if (reduceMotion) {
			gsap.from('.ubicanos-card, .ubicanos-map', {
				autoAlpha: 0,
				duration: 0.3,
				stagger: 0.05,
				scrollTrigger: { trigger: '#ubicanos', start: 'top 75%', toggleActions: 'play none none none' },
			});
			return () => {};
		}

		gsap
			.timeline({
				scrollTrigger: { trigger: '#ubicanos', start: 'top 70%', toggleActions: 'play none none none' },
				defaults: { ease: 'power3.out' },
			})
			.from('.ubicanos-title', { autoAlpha: 0, y: 40, duration: 0.7 })
			.from('.ubicanos-card', { autoAlpha: 0, x: -50, duration: 0.7, stagger: 0.14 }, '-=0.35')
			.from('.ubicanos-map', { autoAlpha: 0, x: 60, scale: 0.96, duration: 0.8 }, '-=0.7')
			.from('.ubicanos-icon', { scale: 0, rotation: -30, duration: 0.5, ease: 'back.out(2)', stagger: 0.1 }, '-=0.7');

		return () => {};
	});
</script>
