---
import { WHATSAPP_URL } from '../lib/contact';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';
---

<div class="whatsapp-float-wrap fixed bottom-6 right-6 z-50">
	<!-- Botón principal -->
	<a
		href={WHATSAPP_URL}
		target="_blank"
		rel="noopener noreferrer"
		aria-label="Escríbenos por WhatsApp"
		aria-describedby="wa-tooltip"
		class="whatsapp-btn relative flex size-16 items-center justify-center rounded-full bg-brand-900 text-gold-400 shadow-2xl ring-2 ring-gold-400/40 transition-colors hover:bg-brand-800 hover:ring-gold-400/70"
	>
		<!-- Halo de pulso -->
		<span class="wa-halo pointer-events-none absolute inset-0 rounded-full bg-gold-400/20" aria-hidden="true"></span>

		<!-- Icono WhatsApp -->
		<WhatsAppIcon class="wa-icon relative size-8 drop-shadow" detailed />
	</a>

	<!-- Tooltip: absolutely positioned so it reserves zero layout space and
	     never reacts to hover while hidden — only .whatsapp-btn's own
	     bounding box triggers it. -->
	<div
		class="whatsapp-tooltip pointer-events-none absolute right-full top-1/2 mr-3 -translate-y-1/2 select-none whitespace-nowrap rounded-xl border border-gold-400/30 bg-brand-900/95 px-4 py-2 text-sm font-semibold text-cream-50 shadow-xl backdrop-blur-sm"
		role="tooltip"
		id="wa-tooltip"
	>
		¡Escríbenos ya! 🐷
		<span class="wa-tooltip-caret absolute right-[-5px] top-1/2 size-2.5 -translate-y-1/2 rotate-45 border-r border-t border-gold-400/30 bg-brand-900/95" aria-hidden="true"></span>
	</div>
</div>

<script>
	import gsap from 'gsap';

	const mm = gsap.matchMedia();

	mm.add(
		{
			reduceMotion: '(prefers-reduced-motion: reduce)',
			okMotion: '(prefers-reduced-motion: no-preference)',
		},
		(context) => {
			const { reduceMotion } = context.conditions as { reduceMotion: boolean };

			const wrap = document.querySelector('.whatsapp-float-wrap') as HTMLElement;
			const btn = document.querySelector('.whatsapp-btn') as HTMLElement;
			const tooltip = document.querySelector('.whatsapp-tooltip') as HTMLElement;
			const halo = document.querySelector('.wa-halo') as HTMLElement;
			const icon = document.querySelector('.wa-icon') as HTMLElement;

			// Entrada desde abajo, con el ícono haciendo un pequeño "pop" detrás.
			gsap.fromTo(
				wrap,
				{ autoAlpha: 0, y: 24, scale: 0.85 },
				{
					autoAlpha: 1,
					y: 0,
					scale: 1,
					duration: reduceMotion ? 0.2 : 0.7,
					ease: 'back.out(1.6)',
					delay: reduceMotion ? 0 : 1.2,
				}
			);

			// Tooltip: oculto por defecto, con un poco de escala para la entrada.
			gsap.set(tooltip, { autoAlpha: 0, x: 10, scale: 0.9 });

			if (!reduceMotion) {
				// Pulso del halo
				gsap.to(halo, {
					scale: 1.55,
					opacity: 0,
					duration: 1.8,
					repeat: -1,
					ease: 'power2.out',
					transformOrigin: 'center center',
				});

				// Botón: leve flotación + un "brinco" de atención cada tanto para
				// llamar la atención sin ser molesto (solo cuando no hay hover).
				let hovering = false;
				gsap.to(btn, { y: -5, duration: 2.2, yoyo: true, repeat: -1, ease: 'sine.inOut', delay: 1.5 });

				const attentionBounce = gsap.timeline({ repeat: -1, repeatDelay: 5, delay: 3 });
				attentionBounce
					.to(icon, { rotation: -14, duration: 0.1, ease: 'power1.out' })
					.to(icon, { rotation: 12, duration: 0.15, ease: 'power1.inOut' })
					.to(icon, { rotation: -8, duration: 0.12, ease: 'power1.inOut' })
					.to(icon, { rotation: 0, duration: 0.15, ease: 'back.out(3)' });

				wrap.addEventListener('mouseenter', () => (hovering = true));
				wrap.addEventListener('mouseleave', () => (hovering = false));
				attentionBounce.eventCallback('onRepeat', () => {
					if (hovering) attentionBounce.progress(0);
				});
			}

			// Hover: el botón se agranda un poco y el tooltip aparece a su lado —
			// ambos escuchan SOLO en el botón, nunca en el hueco donde iría el
			// tooltip (que ahora no ocupa espacio real).
			btn.addEventListener('mouseenter', () => {
				gsap.to(btn, { scale: 1.08, duration: 0.3, ease: 'back.out(2)', overwrite: 'auto' });
				gsap.to(tooltip, { autoAlpha: 1, x: 0, scale: 1, duration: reduceMotion ? 0.1 : 0.3, ease: 'back.out(2.5)' });
			});

			btn.addEventListener('mouseleave', () => {
				gsap.to(btn, { scale: 1, duration: 0.35, ease: 'power2.out', overwrite: 'auto' });
				gsap.to(tooltip, { autoAlpha: 0, x: 10, scale: 0.9, duration: reduceMotion ? 0.1 : 0.2, ease: 'power2.in' });
			});

			return () => {};
		}
	);
</script>
