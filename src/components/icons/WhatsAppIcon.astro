---
interface Props {
	/** Tailwind size classes for the <svg>, e.g. "size-6" or "relative size-8 drop-shadow". */
	class?: string;
	/** Full glyph with the phone-handset detail inside the bubble (used where
	 * the icon stands alone, e.g. floating buttons/cards). Plain bubble
	 * outline otherwise (used inline next to a text label). */
